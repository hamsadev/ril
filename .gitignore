# For a project mostly in C, the following would be a good set of
# exclude patterns (uncomment them if you want to use them):
*.[oa]
*~
# Exclude Drivers folder, can be included
#again using CubeMX
Drivers/
# Ignore build files from Keil uVision
MDK-ARM/DebugConfig/
MDK-ARM/project/
MDK-ARM/RTE/
# Ignore .o .dbgconf .
*.dbgconf
*.o
*.crf
*.d
*.lnp
*.map
*.axf
*.hex
*.sct
*.dep
*.lst
*.fw
*.uvoptx
*.uvguix.*
PDT3.htm
PDT3.build_log.htm
.code-workspace
# Doxygen
/Doxygen/html
*.htm
*.vscode

example/NIRA_STM32F4_EVB/MDK-ARM/JLinkLog.txt
example/NIRA_STM32F4_EVB/MDK-ARM/JLinkSettings.ini
